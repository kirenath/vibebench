# Database
DATABASE_URL=postgresql://user:password@localhost:5432/vibebench

# Admin Authentication
ADMIN_PASSWORD_HASH=$2a$10$your_bcrypt_hash_here
JWT_SECRET=your-random-secret-key-at-least-32-chars

# Public URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
SANDBOX_BASE_URL=http://localhost:3000/s

# File Upload
UPLOAD_DIR=./uploads
UPLOAD_MAX_FILE_SIZE_MB=20
