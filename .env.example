# Core
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
# Optional for this phase. Reserve for later browser-side public reads/auth flows.
NEXT_PUBLIC_SUPABASE_ANON_KEY=[YOUR-ANON-KEY]
# Required now because phase 1 reads public data on the server before RLS/policies are added.
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# Later admin/storage config from PRD
ADMIN_PASSWORD_HASH=
JWT_SECRET=
SANDBOX_BASE_URL=
UPLOAD_DIR=./uploads
UPLOAD_MAX_FILE_SIZE_MB=20
