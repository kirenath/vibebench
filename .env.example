# Database connection string (e.g., PostgreSQL URL)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Admin password hash (bcrypt hash)
ADMIN_PASSWORD_HASH=

# JWT secret key for signing tokens
JWT_SECRET=your_jwt_secret_key_here

# The base URL of the Next.js application
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Base URL for the sandbox execution environment
SANDBOX_BASE_URL=http://localhost:3001

# Directory for file uploads
UPLOAD_DIR=./uploads

# Maximum allowed file upload size in megabytes
UPLOAD_MAX_FILE_SIZE_MB=20
